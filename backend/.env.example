# Backend Environment Variables
FLASK_ENV=production
FLASK_APP=app.py
PYTHONUNBUFFERED=1
DATABASE_URL=sqlite:///aqi_data.db

# API Configuration
API_PORT=5000
CORS_ORIGINS=*

# Optional: If using external AQI data API
WAQI_API_KEY=your_api_key_here

# Optional: If using Claude AI for insights
CLAUDE_API_KEY=your_claude_api_key_here
